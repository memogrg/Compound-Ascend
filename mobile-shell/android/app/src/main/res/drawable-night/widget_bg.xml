<?xml version="1.0" encoding="utf-8"?>
<!-- Fondo del widget (OSCURO) — robusto para RemoteViews/EMUI: gradiente LINEAL redondeado +
     borde acento (sin la capa radial). Tokens .dark del design system. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <corners android:radius="24dp" />
    <gradient
        android:type="linear"
        android:angle="315"
        android:startColor="#253122"
        android:endColor="#1E1C16" />
    <stroke
        android:width="1dp"
        android:color="#374E38" />
</shape>
