<?xml version="1.0" encoding="utf-8"?>
<!-- Fondo PREMIUM del widget (variante CLARA) — clon de .hero-nw / .wgt-nw (mobile.css).
     Capa 1: linear ~155° de color-mix(accent 14%, surface)=#E3EEE7 a surface=#FFFFFF, borde
     1dp accent 26%=#B9CBB8. Capa 2: glow RADIAL verde arriba-derecha (accent @22% -> transp).
     RemoteViews no hace sombra de vista; el look premium sale del gradiente + glow + borde. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base: gradiente lineal diagonal + borde acento -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:type="linear"
                android:angle="315"
                android:startColor="#E3EEE7"
                android:endColor="#FFFFFF" />
            <stroke
                android:width="1dp"
                android:color="#B9CBB8" />
        </shape>
    </item>

    <!-- Glow radial verde en la esquina superior derecha -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:type="radial"
                android:centerX="0.82"
                android:centerY="0.0"
                android:gradientRadius="170dp"
                android:startColor="#38378451"
                android:endColor="#00378451" />
        </shape>
    </item>
</layer-list>
