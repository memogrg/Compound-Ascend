<?xml version="1.0" encoding="utf-8"?>
<!-- Fondo del widget (CLARO) — robusto para RemoteViews/EMUI: gradiente LINEAL redondeado +
     borde acento (sin la capa radial, que algunos launchers no inflan). Look premium igual. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <corners android:radius="24dp" />
    <gradient
        android:type="linear"
        android:angle="315"
        android:startColor="#E3EEE7"
        android:endColor="#FFFFFF" />
    <stroke
        android:width="1dp"
        android:color="#B9CBB8" />
</shape>
