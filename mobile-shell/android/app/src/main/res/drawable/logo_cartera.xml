<?xml version="1.0" encoding="utf-8"?>
<!-- Logo oficial CARTERA+ (variante CLARA). Conversión fiel de assets/cartera-logo-light.svg:
     badge rounded-square + monograma "C+" (arco C + cruz verde). El transform anidado del SVG
     (translate 512,512 · scale 16 · translate -32,-32) se reduce EXACTAMENTE a scale(16). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="1024"
    android:viewportHeight="1024">

    <!-- Badge: cuadrado redondeado (r=224) con borde sutil -->
    <path
        android:pathData="M224,0 L800,0 A224,224 0 0 1 1024,224 L1024,800 A224,224 0 0 1 800,1024 L224,1024 A224,224 0 0 1 0,800 L0,224 A224,224 0 0 1 224,0 Z"
        android:fillColor="#FFFFFF"
        android:strokeColor="#B2C7B2"
        android:strokeWidth="6" />

    <!-- Monograma, en coords originales del SVG escaladas x16 -->
    <group
        android:scaleX="16"
        android:scaleY="16">
        <!-- Arco "C" (abre a la derecha) -->
        <path
            android:pathData="M45,18.5 A19,19 0 1 0 45,45.5"
            android:strokeColor="#1E1C16"
            android:strokeWidth="7"
            android:strokeLineCap="round" />
        <!-- Cruz "+" verde en la apertura de la C -->
        <path
            android:pathData="M45,27 L45,37 M40,32 L50,32"
            android:strokeColor="#378451"
            android:strokeWidth="4.4"
            android:strokeLineCap="round" />
    </group>
</vector>
