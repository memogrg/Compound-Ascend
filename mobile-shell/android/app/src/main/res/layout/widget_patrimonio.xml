<?xml version="1.0" encoding="utf-8"?>
<!-- Widget "Patrimonio neto" — versión ROBUSTA para RemoteViews (EMUI/Android 10).
     SIN fuentes @font ni vector drawables (el launcher de EMUI no los infla): el monto grande
     se pinta como BITMAP en el provider con Space Mono real; los textos chicos usan fuentes del
     sistema (sans-serif-medium); el logo es un PNG. El look premium sale del fondo + el bitmap. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="18dp">

    <!-- Fila 1: etiqueta + logo (PNG) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tv_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="PATRIMONIO NETO"
            android:fontFamily="sans-serif-medium"
            android:textSize="10sp"
            android:letterSpacing="0.14"
            android:textColor="@color/widget_muted" />

        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/logo_cartera"
            android:contentDescription="CARTERA+" />
    </RelativeLayout>

    <!-- Fila 2: monto (bitmap Space Mono) a la izquierda, tendencia a la derecha -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:gravity="bottom"
        android:layout_marginTop="8dp">

        <ImageView
            android:id="@+id/iv_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:contentDescription="@null" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tv_trend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:paddingBottom="3dp"
            android:text=""
            android:fontFamily="sans-serif-medium"
            android:textSize="12sp"
            android:maxLines="1"
            android:textColor="@color/widget_accent" />
    </LinearLayout>

    <!-- Fila 3: Ingresos · Gastos · Flujo (fuentes del sistema) -->
    <LinearLayout
        android:id="@+id/flow_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:layout_marginTop="13dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ingresos"
                android:fontFamily="sans-serif"
                android:textSize="9sp"
                android:textColor="@color/widget_muted" />

            <TextView
                android:id="@+id/tv_income"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text=""
                android:fontFamily="sans-serif-medium"
                android:textSize="13sp"
                android:maxLines="1"
                android:textColor="@color/widget_accent" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical"
            android:layout_marginHorizontal="12dp"
            android:background="@color/widget_border" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gastos"
                android:fontFamily="sans-serif"
                android:textSize="9sp"
                android:textColor="@color/widget_muted" />

            <TextView
                android:id="@+id/tv_expense"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text=""
                android:fontFamily="sans-serif-medium"
                android:textSize="13sp"
                android:maxLines="1"
                android:textColor="@color/widget_danger" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical"
            android:layout_marginHorizontal="12dp"
            android:background="@color/widget_border" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Flujo"
                android:fontFamily="sans-serif"
                android:textSize="9sp"
                android:textColor="@color/widget_muted" />

            <TextView
                android:id="@+id/tv_flow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text=""
                android:fontFamily="sans-serif-medium"
                android:textSize="13sp"
                android:maxLines="1"
                android:textColor="@color/widget_accent" />
        </LinearLayout>
    </LinearLayout>

    <!-- Fila 4: actualizado hh:mm -->
    <TextView
        android:id="@+id/tv_updated"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text=""
        android:fontFamily="sans-serif"
        android:textSize="9.5sp"
        android:textColor="@color/widget_muted" />
</LinearLayout>
