# ============================================================
# Compound Ascend — variables de entorno (EJEMPLO, sin secretos)
# Copia a .env.local y rellena. NUNCA commitees .env.local.
# Las claves marcadas (BACKEND) jamás deben llevar prefijo NEXT_PUBLIC_.
# ============================================================

# --- Ambiente ---
NODE_ENV=development
APP_ENV=development                       # development | staging | production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- CORS / orígenes permitidos (coma-separados, sin wildcard en prod) ---
ALLOWED_ORIGINS=http://localhost:3000

# --- Supabase (público: seguro exponer) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (BACKEND: service role — JAMÁS al frontend) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- IA (BACKEND) ---
# OJO: las keys del handoff están comprometidas. Genera nuevas.
AI_PROVIDER=gemini                        # gemini | (futuro: otros)
GEMINI_API_KEY=

# --- Market data (BACKEND) ---
FINNHUB_TOKEN=
ALPHA_VANTAGE_KEY=
# Yahoo Finance, Binance y CoinGecko no requieren key.

# --- Cache (opcional) ---
REDIS_URL=                                # si vacío, fallback en memoria

# --- Anti-bot (opcional en dev, requerido en prod) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Pagos / monetización (BACKEND) ---
# Secreto para verificar la firma del webhook de pagos (cambios de plan).
PAYMENT_WEBHOOK_SECRET=

# --- Cron / tareas programadas (BACKEND) ---
# Secreto para autenticar llamadas al endpoint POST /api/investments/snapshot.
# Usar desde Vercel Cron, GitHub Actions o cualquier scheduler externo.
CRON_SECRET=
