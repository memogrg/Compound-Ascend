# ============================================================
# CARTERA+ — variables de entorno (EJEMPLO, sin secretos)
# Copia a .env.local y rellena. NUNCA commitees .env.local.
# Las claves marcadas (BACKEND) jamás deben llevar prefijo NEXT_PUBLIC_.
# ============================================================

# --- Ambiente ---
NODE_ENV=development
APP_ENV=development                       # development | staging | production
NEXT_PUBLIC_APP_URL=http://localhost:3000   # prod: https://cartera.vercel.app

# --- CORS / orígenes permitidos (coma-separados, sin wildcard en prod) ---
ALLOWED_ORIGINS=http://localhost:3000       # prod: https://cartera.vercel.app,http://localhost:3000

# --- Supabase (público: seguro exponer) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (BACKEND: service role — JAMÁS al frontend) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- IA (BACKEND) ---
# OJO: las keys del handoff están comprometidas. Genera nuevas.
AI_PROVIDER=gemini                        # gemini | (futuro: otros)
GEMINI_API_KEY=

# --- Market data (BACKEND) ---
FINNHUB_TOKEN=
ALPHA_VANTAGE_KEY=
# Yahoo Finance, Binance y CoinGecko no requieren key.

# --- Indicadores económicos (BACKEND) ---
# Costa Rica · BCCR (API SDDE, REST/JSON con Bearer) — https://www.bccr.fi.cr/indicadores-economicos
BCCR_SDDE_TOKEN=                          # token Bearer (JWT) de la suscripción SDDE
BCCR_SDDE_EMAIL=                          # correo de la suscripción (informativo)
# EE. UU. · FRED (Fase 2) — key gratis: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# --- Cache (opcional) ---
REDIS_URL=                                # si vacío, fallback en memoria

# --- Rate-limit distribuido · Upstash Redis (REST) ---
# Requerido en producción (Vercel multi-instancia): sin esto el rate-limit es
# por instancia y se puede evadir escalando lambdas. Crear base en
# https://console.upstash.com → Redis → REST API.
UPSTASH_REDIS_REST_URL=                   # https://<db>.upstash.io
UPSTASH_REDIS_REST_TOKEN=                 # token REST de la base

# --- Observabilidad (opcional, recomendado en prod) ---
# Sentry: captura errores de servidor y navegador. Inerte sin DSN.
NEXT_PUBLIC_SENTRY_DSN=                    # DSN del proyecto Sentry (cliente)
SENTRY_DSN=                               # mismo DSN (server/edge); opcional
# Alertas operativas a Slack (Incoming Webhook). Si falta, solo van al log.
SLACK_ALERT_WEBHOOK_URL=                  # https://hooks.slack.com/services/...

# --- Anti-bot (opcional en dev, requerido en prod) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Pagos / monetización (BACKEND) ---
# Secreto para verificar la firma del webhook de pagos (cambios de plan).
PAYMENT_WEBHOOK_SECRET=

# --- Cron / tareas programadas (BACKEND) ---
# Secreto para autenticar /api/investments/snapshot y /api/indicators/refresh.
# Usar desde Vercel Cron, GitHub Actions o cualquier scheduler externo.
CRON_SECRET=

# --- WhatsApp (Twilio) (BACKEND) ---
# Asistente por WhatsApp (gastos por foto/texto + consultas). Si faltan, la
# integración se omite con gracia. Ver docs/whatsapp-setup.md.
TWILIO_ACCOUNT_SID=                        # SID de la cuenta Twilio (ACxxxxxxxx)
TWILIO_AUTH_TOKEN=                         # Auth Token (también firma los webhooks)
TWILIO_WHATSAPP_NUMBER=                    # E.164, p. ej. +14155238886 (sandbox)
